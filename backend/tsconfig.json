{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "declaration": true,
    "lib": ["dom", "esnext"],
    "types": ["node"] // Add this line to include node types
  },
  "include": [
    "index.ts",
    "src/config/dbConnect.ts",
    "src/config/static.ts",
    "src/controller/user/**/*",
    "src/controller/createpost/**/*",
    "src/controller/comment/**/*",
    "src/controller/follow/**/*",
    "src/controller/like/**/*",
    "src/controller/env/**/*",
    "src/middleware/index.ts",
    "src/middleware/auth/auth.middleware.ts",
    "src/middleware/error/errorHandler.ts",
    "src/middleware/upload/upload.middleware.ts",
    "src/model/**/*.js",
    "src/routes/index.ts",
    "src/routes/user/**/*",
    "src/routes/createpost/**/*",
    "src/routes/comment/**/*",
    "src/routes/follow/**/*",
    "src/routes/like/**/*",
    "src/routes/env/**/*",
    "src/socket/**/*",
    "src/utils/response/**/*",
    "src/utils/cloudinary.js"
  ],
  "exclude": ["node_modules"]
}
